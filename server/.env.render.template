# Copy this to a local Render-only env file if you want to test a hosted backend config.
# Render injects PORT automatically; do not set it here.
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=https://your-project.pages.dev
NODE_ENV=production
DEBUG_REQUESTS=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_BUCKET=images
ACTION_LOGGING_ENABLED=true
